# ─────────────────────────────────────────────────────────────────────
# MeetMind environment configuration
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ── Database ─────────────────────────────────────────────────────────
# Default for local dev (no install required). docker-compose overrides
# this to PostgreSQL inside the backend container.
DATABASE_URL=sqlite:///./meetmind.db
# DATABASE_URL=postgresql://meetmind:meetmind@localhost:5432/meetmind

# ── Qdrant ───────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── LLM ──────────────────────────────────────────────────────────────
# Providers:
#   ollama = local Ollama server, no API key required
#   openai = OpenAI or any OpenAI-compatible /chat/completions endpoint
LLM_PROVIDER=ollama
LLM_MODEL_NAME=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# For OpenAI-compatible hosted models, set:
# LLM_PROVIDER=openai
# LLM_MODEL_NAME=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_SSL_VERIFY=true
# Set true only on corporate networks that intercept TLS certificates.
MEETMIND_DISABLE_SSL_VERIFY=false
LLM_TIMEOUT_SECONDS=180
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ── Speech-to-Text (faster-whisper) ──────────────────────────────────
# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
# Device: auto | cpu | cuda. GPU works because app.services.gpu.prime_cuda()
# loads torch's cuDNN 9 before CTranslate2, so CTranslate2 shares it. "auto"
# uses the GPU when present (float16) and falls back to CPU int8 otherwise.
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto

# ── Speaker Diarization (pyannote.audio) ─────────────────────────────
# Optional: leave empty to skip diarization (all speakers labelled "Speaker").
# To enable:
#   1. Accept license at https://huggingface.co/pyannote/speaker-diarization-3.1
#   2. Create a token at https://huggingface.co/settings/tokens
#   3. Set the token below and restart the backend.
PYANNOTE_AUTH_TOKEN=hf_...
ENABLE_DIARIZATION=true
# Diarization is the heaviest stage; runs on GPU when available (same model,
# identical output, ~10-20x faster). auto | cpu | cuda.
DIARIZATION_DEVICE=auto

# ── Embeddings ───────────────────────────────────────────────────────
TEXT_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
TEXT_EMBEDDING_DIM=768
CLIP_MODEL=openai/clip-vit-base-patch32
CLIP_DIM=512
# Keep cpu on small GPUs to leave VRAM for Whisper + diarization. auto | cpu | cuda.
EMBEDDING_DEVICE=cpu

# ── Video Processing ─────────────────────────────────────────────────
FRAME_INTERVAL_SECONDS=5
ENABLE_FRAME_EXTRACTION=true
ENABLE_OCR=true

# ── Storage ──────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
FRAMES_DIR=frames
AUDIO_DIR=audio
MAX_UPLOAD_MB=2048

# ── Processing ───────────────────────────────────────────────────────
# Wall-clock budget per meeting, enforced cooperatively between pipeline
# stages. Set to 0 to disable. (~2h covers a full 500MB+ video on CPU.)
PROCESSING_TIMEOUT_SECONDS=7200
