# ─────────────────────────────────────────────────────────────────────
# MeetMind environment configuration
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────
# Overridden by docker-compose for the backend container
DATABASE_URL=postgresql://meetmind:meetmind@localhost:5432/meetmind

# ── Qdrant ───────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── QGenie LLM ───────────────────────────────────────────────────────
# QGenie is an OpenAI-compatible proxy (same pattern as jira_hop_detector.py).
# POST {QGENIE_ENDPOINT}/chat/completions with Bearer auth.
QGENIE_ENDPOINT=https://qgenie-api.qualcomm.com/v1
QGENIE_API_KEY=8720595d-a824-4a8f-8da2-b42e98324e07

# Model routed by QGenie. Examples:
#   vertexai::gemini-3.1-pro-preview
#   anthropic::claude-3-5-sonnet-20241022
#   openai::gpt-4o
LLM_MODEL_NAME=vertexai::gemini-3.1-pro-preview
LLM_TIMEOUT_SECONDS=180
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ── Speech-to-Text (faster-whisper) ──────────────────────────────────
# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Speaker Diarization (pyannote.audio) ─────────────────────────────
# Optional: leave empty to skip diarization (all speakers labelled "Speaker").
# To enable:
#   1. Accept license at https://huggingface.co/pyannote/speaker-diarization-3.1
#   2. Create a token at https://huggingface.co/settings/tokens
#   3. Set the token below and restart the backend.
PYANNOTE_AUTH_TOKEN=
ENABLE_DIARIZATION=true

# ── Embeddings ───────────────────────────────────────────────────────
TEXT_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
TEXT_EMBEDDING_DIM=768
CLIP_MODEL=openai/clip-vit-base-patch32
CLIP_DIM=512

# ── Video Processing ─────────────────────────────────────────────────
FRAME_INTERVAL_SECONDS=5
ENABLE_FRAME_EXTRACTION=true
ENABLE_OCR=true

# ── Storage ──────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
FRAMES_DIR=frames
AUDIO_DIR=audio
MAX_UPLOAD_MB=500

# ── Processing ───────────────────────────────────────────────────────
PROCESSING_TIMEOUT_SECONDS=3600
